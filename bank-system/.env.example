# Copy this file to .env and fill with your own values.
# .env is ignored by git and loaded automatically by Spring.

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/bank_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=bank_user
SPRING_DATASOURCE_PASSWORD=bank_password

# Security
APP_ADMIN_SECRET=SuperSecretAdminKey123
JWT_SECRET_BASE64=c3VwZXJzZWNyZXRzdXBlcnNlY3JldHN1cGVyc2VjcmV0MTIzNDU2
JWT_EXPIRATION_MS=7200000

# Bootstrap employee
BOOTSTRAP_EMPLOYEE_EMAIL=employee@bank.local
BOOTSTRAP_EMPLOYEE_PASSWORD=Employee@123

# Mail
# Dev (MailHog)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=false
MAIL_SMTP_SSL=true
APP_MAIL_FROM=no-reply@bank-system.local

# Real SMTP example values (replace above when needed)
# MAIL_HOST=smtp.provider.com
# MAIL_PORT=587
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# MAIL_SMTP_SSL=false
# APP_MAIL_FROM=your@email.com

